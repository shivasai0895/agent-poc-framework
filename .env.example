# ── Auth ─────────────────────────────────────────────────────────────────────
# Option A: AI Studio key (local dev, no GCP billing)
GOOGLE_API_KEY=

# Option B: Vertex AI (GCP project required)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Use `gcloud auth application-default login` or point to a service account:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Model ────────────────────────────────────────────────────────────────────
ADK_MODEL=gemini-2.5-flash

# ── Session backend ──────────────────────────────────────────────────────────
# false = InMemory (local dev), true = Vertex AI session service
USE_VERTEX_AI=false

# ── UI: Slack (if using slack integration) ───────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── UI: Teams (if using teams integration) ───────────────────────────────────
# MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD=
